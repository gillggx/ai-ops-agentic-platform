# 2026-05-08 — visx 3.12 declares peer dep react ^16/17/18, but the project
# is on React 19. visx works fine with React 19 in practice (the constraint
# is just type-level), so allow installs to proceed without --legacy-peer-deps
# on every command. Drop this once visx 4.x stable lands with React 19 peer.
legacy-peer-deps=true
