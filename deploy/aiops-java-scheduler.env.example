# /opt/aiops/java-scheduler/.env — Java Scheduler service (Phase 2)
# Copy to .env on the server and fill in real secrets.
# Most secrets are SHARED with java-backend's .env — keep them aligned.

# Runtime
AIOPS_PROFILE=prod
AIOPS_SCHEDULER_PORT=8003

# DB (same Postgres cluster + DB as the API service)
DB_URL=jdbc:postgresql://localhost:5432/aiops
DB_USER=aiops
DB_PASSWORD=CHANGE_ME

# Internal HTTP token — API service must send this in X-Internal-Token
# when calling /internal/scheduler/*. Same value as
# AIOPS_SCHEDULER_INTERNAL_TOKEN in java-backend/.env.
AIOPS_SCHEDULER_INTERNAL_TOKEN=CHANGE_ME_SCHEDULER_TOKEN

# Python sidecar (downstream, used by AutoPatrolExecutor when running
# pipelines). Same value as in java-backend/.env.
PYTHON_SIDECAR_URL=http://127.0.0.1:8050
PYTHON_SIDECAR_TOKEN=CHANGE_ME_SIDECAR_TOKEN

# Ontology simulator (read-only, for EventPollerService).
ONTOLOGY_SIM_URL=http://127.0.0.1:8012

# Audit retention (kept separate so it can differ from API value).
AIOPS_AUDIT_RETENTION_DAYS=90

# Phase 3 — Redis distributed lock backend (multi-pod scheduler safety).
# Single-pod deploys can leave fail-open=true and a Redis blip won't
# stop scheduled jobs. Multi-pod deploys MUST have Redis up.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
AIOPS_LOCK_NAMESPACE=aiops:lock
AIOPS_LOCK_FAIL_OPEN=true
