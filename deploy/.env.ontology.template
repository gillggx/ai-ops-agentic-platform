# OntologySimulator — Production 環境變數
# 複製為 /opt/aiops/ontology_simulator/.env 並填入真實值

# ── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB="semiconductor_sim"

# ── Server ────────────────────────────────────────────────────────
PORT=8001

# ── 模擬參數（production 建議放慢速度）────────────────────────────
PROCESSING_MIN=600
PROCESSING_MAX=900
HEARTBEAT_MIN=5
HEARTBEAT_MAX=10
OOC_PROBABILITY=0.10
HOLD_PROBABILITY=0.05
RECYCLE_LOTS=true
