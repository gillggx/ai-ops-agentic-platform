# Copy to deploy/docker/.env and fill the REQUIRED values before
#   docker compose -f deploy/docker-compose.yml --env-file deploy/docker/.env up -d

# === REQUIRED ===
# Shared internal-service token. Same value used by aiops-app proxy routes,
# java-api InternalServiceTokenFilter, sidecar SERVICE_TOKEN, scheduler.
# Generate: openssl rand -hex 32
INTERNAL_API_TOKEN=

# NextAuth session signing key. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Postgres password. Used by postgres init + java SPRING_DATASOURCE_PASSWORD.
POSTGRES_PASSWORD=

# === LLM provider (one of these set + LLM_PROVIDER matching) ===
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=

# === Optional ===
LOG_LEVEL=INFO
NEXTAUTH_URL=http://localhost:8000
