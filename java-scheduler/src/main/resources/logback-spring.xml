<?xml version="1.0" encoding="UTF-8"?>
<!--
  Structured JSON logging to stdout. Schema in docs/logging-schema.md.
  service="aiops-java-scheduler". MDC.trace_id is set by TraceIdFilter on
  inbound HTTP; for cron-driven jobs the scheduler sets a "task_<uuid>" id
  at job-start so background activity still groups in Kibana.
-->
<configuration>

    <springProperty name="LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <level>level</level>
                <logger>logger</logger>
                <message>message</message>
                <thread>[ignore]</thread>
                <levelValue>[ignore]</levelValue>
                <version>[ignore]</version>
            </fieldNames>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
            <includeMdcKeyName>trace_id</includeMdcKeyName>
            <customFields>{"service":"aiops-java-scheduler"}</customFields>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="STDOUT"/>
    </root>

    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.springframework.web" level="INFO"/>

</configuration>
