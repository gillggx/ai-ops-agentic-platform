# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, dev only)
DATABASE_URL=sqlite+aiosqlite:///./database.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aiops

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
INTERNAL_API_TOKEN=change-me-internal-token

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic             # anthropic | ollama
LLM_MODEL=claude-haiku-4-5-20251001

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama / OpenAI-compatible (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
OLLAMA_API_KEY=ollama

# ── Memory ────────────────────────────────────────────────────────────────────
MEM0_API_KEY=                      # optional — leave empty to skip Mem0

# ── Services ──────────────────────────────────────────────────────────────────
ONTOLOGY_SIM_URL=http://localhost:8012
NATS_URL=nats://localhost:4222     # optional

# ── Frontend (aiops-app/.env.local) ───────────────────────────────────────────
# FASTAPI_BASE_URL=http://localhost:8000
# INTERNAL_API_TOKEN=change-me-internal-token   (same as above)
# NEXT_PUBLIC_APP_TITLE=AIOps Platform
