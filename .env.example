# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | production

# ── Logging ───────────────────────────────────────────────────────────────────
# JSON-on-stdout for all 4 services (sidecar, simulator, java-api, java-scheduler).
# Schema in docs/logging-schema.md. Use INFO in prod, DEBUG only in dev.
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, dev only)
DATABASE_URL=sqlite+aiosqlite:///./database.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aiops

# ── Security (REQUIRED in production — `aiops-app` build will fail otherwise) ─
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# REQUIRED. Must be >=16 chars, NOT "dev-token" or "change-me-internal-token".
# Same value must be set in java-backend INTERNAL_API_TOKEN.
# Generate: openssl rand -hex 32
INTERNAL_API_TOKEN=change-me-internal-token

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic             # anthropic | ollama | internal-proxy
LLM_MODEL=claude-haiku-4-5-20251001

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama / OpenAI-compatible (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
OLLAMA_API_KEY=ollama

# Internal LLM proxy (required when LLM_PROVIDER=internal-proxy).
# OpenAI-compatible endpoint with a custom auth header (e.g. X-API-Key).
# Leave INTERNAL_PROXY_API_KEY blank if the proxy only uses the custom header.
INTERNAL_PROXY_BASE_URL=http://llm-service:8080
INTERNAL_PROXY_API_KEY=
INTERNAL_PROXY_HEADER_NAME=X-API-Key
INTERNAL_PROXY_HEADER_VALUE=secret-key-xyz

# ── Memory ────────────────────────────────────────────────────────────────────
MEM0_API_KEY=                      # optional — leave empty to skip Mem0

# ── Services ──────────────────────────────────────────────────────────────────
ONTOLOGY_SIM_URL=http://localhost:8012
NATS_URL=nats://localhost:4222     # optional

# ── Internal IP allow-lists (token still gates; this is defence-in-depth) ─────
# Both Java InternalServiceTokenFilter (java-backend) and Python sidecar auth.py
# support plain IPs and CIDR ranges (e.g. 172.16.0.0/12 for Docker bridge).
# Leave blank to disable IP filtering entirely.
ALLOWED_CALLERS=127.0.0.1,::1
JAVA_INTERNAL_ALLOWED_IPS=127.0.0.1,::1

# ── Frontend (aiops-app/.env.local) ───────────────────────────────────────────
# Required in production (build:prod will fail if missing):
#   INTERNAL_API_TOKEN   (>=16 chars, mirrors backend)
#   NEXTAUTH_SECRET      (>=32 chars; generate: openssl rand -base64 32)
#   FASTAPI_BASE_URL     (Java backend URL)
# Optional dev defaults:
#   FASTAPI_BASE_URL=http://localhost:8002
#   ONTOLOGY_BASE_URL=http://localhost:8012
#   NEXT_PUBLIC_APP_TITLE=AIOps Platform
